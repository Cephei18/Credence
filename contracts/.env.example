# Deployer key (Base Sepolia). Fund with testnet ETH from a Base Sepolia faucet.
DEPLOYER_PRIVATE_KEY=

# RPC + explorer
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=

# Used by scripts/resolve.ts to simulate the Chainlink callback locally
VERIFIER_ADDRESS=
AGENT_ID=1
SUCCESS=true

# --- Chainlink Functions (real DON verifier — Commit 5) ---
# VERIFY current values at https://docs.chain.link/chainlink-functions/supported-networks
# Base Sepolia Functions router + DON id:
FUNCTIONS_ROUTER=0xf9B8fc078197181C841c296C876945aaa425B278
FUNCTIONS_DON_ID=fun-base-sepolia-1
# Create a subscription at https://functions.chain.link (Base Sepolia), then paste its id:
FUNCTIONS_SUBSCRIPTION_ID=
# Callback gas for fulfillVerification — must be <= router max (300000 on Base Sepolia):
FUNCTIONS_CALLBACK_GAS_LIMIT=300000

# AgentPassport address on Base Sepolia (printed by deploy:baseSepolia) — consumed by deploy:chainlink + smoke:chainlink
PASSPORT_ADDRESS=

# Base Sepolia LINK token (fund the subscription with this) — reference only:
# LINK_TOKEN=0xE4aB69C077896252FAFBD49EFD26B5D171A32410
